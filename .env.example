# GROQ_API_KEY: Required for Groq AI API calls.
# Get your API key at https://console.groq.com
# Set this as an environment variable in Vercel (Production, Preview, Development)
GROQ_API_KEY="your_groq_api_key_here"

# TTS_API_KEY: Required for ElevenLabs Text-to-Speech API (voces premium HD).
# Get your API key at https://elevenlabs.io
# Set this as an environment variable in Vercel (Production, Preview, Development)
TTS_API_KEY="your_elevenlabs_api_key_here"

# APP_URL: The URL where this applet is hosted.
APP_URL="https://your-app.vercel.app"

# GOOGLE_OAUTH_CLIENT_ID: Client ID for Google Sign-In (frontend).
# Create at https://console.cloud.google.com/apis/credentials → OAuth 2.0 Client IDs
VITE_GOOGLE_CLIENT_ID="your_google_client_id_here"

# GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET: Backend OAuth to verify tokens.
# Same client as above; secret from the same OAuth 2.0 credential page.
GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# GOOGLE_SERVICE_ACCOUNT_JSON: Full JSON content of the Service Account key.
# This SA needs: Editor access to the Spreadsheet + Domain-wide Gmail send delegation.
# Convert the entire JSON to a single-line string and set it here.
# NEVER commit this value — use Vercel env vars or a .env.local file.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'

# GOOGLE_SERVICE_ACCOUNT_PATH: Alternative to GOOGLE_SERVICE_ACCOUNT_JSON for local dev.
# Points to the JSON file on disk. Only used if GOOGLE_SERVICE_ACCOUNT_JSON is not set.
GOOGLE_SERVICE_ACCOUNT_PATH="C:\path\to\service-account.json"

# IMPORTANT: Share the spreadsheet with the Service Account email as EDITOR.
# SA Email (found in the JSON): teclingo-vlight-vi@teclingo-vlight-vi.iam.gserviceaccount.com

# GOOGLE_SHEET_ID: Spreadsheet ID extracted from the URL:
# https://docs.google.com/spreadsheets/d/1JgLCxpi81K776wRwji92KJLUoYaPirBcX2aRxs4q7hk/edit?gid=0
GOOGLE_SHEET_ID="1JgLCxpi81K776wRwji92KJLUoYaPirBcX2aRxs4q7hk"
