              <div className="flex flex-col md:flex-row gap-6 justify-between items-start md:items-center bg-black/40 p-8 rounded-[2.5rem] border border-white/5 backdrop-blur-xl">
                
                {/* SELECTOR CRÍTICO: CARGA DE GRUPOS AL GRID */}
