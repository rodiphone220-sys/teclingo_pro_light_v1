                          item.accent === 'green' ? 'bg-[#40b06b]/15 text-[#4ade80]' :
                          item.accent === 'cyan' ? 'bg-[#22D3EE]/15 text-[#22D3EE]' :
                          item.accent === 'orange' ? 'bg-[#F59E0B]/15 text-[#F59E0B]' :
                          'bg-[#a855f7]/15 text-[#c084fc]'
