                      >
                         Confirmar Cita
                      </button>
                   </div>
                </motion.div>
             </div>
           )}
        </AnimatePresence>

        <AnimatePresence>
           {showToast && (
             <motion.div
               initial={{ opacity: 0, y: 50, scale: 0.9 }}
               animate={{ opacity: 1, y: 0, scale: 1 }}
