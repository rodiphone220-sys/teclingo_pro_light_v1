      icon: 'Leaf' as const,
      accent: 'cyan' as const,
      isLeader: false
    },
    {
      title: 'HISTORIAN COGNITIVO',
      description: 'Dominó de forma impecable las lecciones cronológicas de gramática y vocabulario.',
