           </div>

           {/* Box 3: Recording Lab */}
           <div className="p-6 rounded-[2.5rem] bg-[#DEFF9A]/5 border border-[#DEFF9A]/10 flex flex-col items-center justify-center text-center space-y-6 min-h-[320px] relative overflow-hidden group">
