    setList(prev => [newAward, ...prev]);
    setIsSuccessAnimated(true);

    // Reset some fields or notify
    setTimeout(() => {
      setIsSuccessAnimated(false);
    }, 4000);
  };

  const handleRevokeAward = (id: string) => {
    setList(prev => prev.filter(item => item.id !== id));
