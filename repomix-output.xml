                    <span className="text-[8px] font-black uppercase text-purple-400 tracking-widest">{lvl === 'A1' || lvl === 'A2' ? 'Basic' : lvl === 'B1' || lvl === 'B2' ? 'Intermediate' : 'Advanced'}</span>
                 </button>
