              </div>
              <div className="mt-8 pt-8 border-t border-white/5 flex items-center justify-between">
                 <div className="flex items-center gap-4">
                    <div className="p-3 rounded-xl bg-[#DEFF9A]/10 text-[#DEFF9A]">
                       <Trophy size={20} />
