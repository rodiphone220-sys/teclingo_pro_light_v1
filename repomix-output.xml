                               </span>
                             </button>
                           );
                         })}
                      </div>
                   </div>

                   {/* Footer Controls */}
                   <div className="mt-8 pt-6 border-t border-gray-800 flex items-center justify-between gap-4">
                      <p className="text-[9px] text-white/30 uppercase tracking-widest max-w-[200px]">
