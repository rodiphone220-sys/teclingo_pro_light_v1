                      </button>
                      <div className="flex items-center gap-3 mt-1">
                         <span className="text-[8px] font-black text-[#DEFF9A] uppercase tracking-widest bg-[#DEFF9A]/10 px-2.5 py-1 rounded-lg border border-[#DEFF9A]/20">
