      // Group by day to make a beautiful display
      const daysOrder = ['LUNES', 'MARTES', 'MIÉRCOLES', 'JUEVES', 'VIERNES', 'SÁBADO'];
      daysOrder.forEach(dia => {
        const slotsInDay = docenteClasses.filter(c => c.day === dia);
